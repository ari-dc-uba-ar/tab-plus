{
    "compilerOptions": {
        "target": "ES2019",
        "lib": ["ES2019"],
        "module": "commonjs",
        "declaration": true,
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true
    },
    "include": ["src/**/*.ts"]
}
